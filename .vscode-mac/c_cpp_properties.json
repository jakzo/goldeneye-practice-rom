{
    "configurations": [
        {
            "name": "GoldenEye Practice ROM",
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/include",
                "${workspaceFolder}/include/ultra64",
                "${workspaceFolder}/include/PR",
                "${workspaceFolder}/src",
                "${workspaceFolder}/src/game",
                "${workspaceFolder}/src/inflate",
                "${workspaceFolder}/src/practice",
                "${workspaceFolder}/src/practice/state"
            ],
            "defines": [
                "DEV",
                "VERSION_US",
                "TARGET_N64",
                "PRACTICE_ROM",
                "LANG_US",
                "REFRESH_NTSC",
                "LEFTOVERDEBUG",
                "LEFTOVERSPECTRUM",
                "BUGFIX_R0",
                "BYTEMATCH",
                "ENABLE_USB",
                "_LANGUAGE_C"
            ],
            "cStandard": "gnu89",
            "cppStandard": "c++11",
            "intelliSenseMode": "macos-clang-arm64",
            "compilerPath": "/usr/bin/clang",
            "compilerArgs": [
                "-fms-extensions",
                "-ffreestanding",
                "-fno-builtin",
                "-funsigned-char",
                "-fno-short-enums",
                "-target",
                "mips-linux-gnu",
                "-mips3",
                "-mabi=32"
            ]
        }
    ],
    "version": 4
}
